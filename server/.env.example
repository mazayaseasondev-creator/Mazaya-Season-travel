# Copy this file to ".env" and fill in real values for your environment.

# Web server
PORT=4000
NODE_ENV=development

# PostgreSQL connection.
# Either set a full connection string...
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/mazaya
# ...or leave DATABASE_URL unset and use the standard PG* variables instead:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=mazaya
# PGPASSWORD=secret
# PGDATABASE=mazaya

# Secrets - generate long random strings for production (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-in-production
OTP_SECRET=change-me-in-production

# One-time-code settings
OTP_TTL_MINUTES=5
OTP_MAX_ATTEMPTS=5
SESSION_TTL_DAYS=30

# DEV ONLY: when true (and not production), the OTP code is returned in the API
# response so you can log in without a real SMS/email provider. Set to false
# (or run with NODE_ENV=production) to disable.
EXPOSE_OTP=true

# Path to the static front-end to serve. Defaults to the repository root.
# STATIC_DIR=..

# --- Phase 2: visas, document uploads and payments ---

# Identifiers (emails / mobiles) granted the admin role on login. Comma-separated.
# ADMIN_IDENTIFIERS=ops@mazaya.com,+971500000000

# Public origin used to build payment return/redirect URLs.
# PUBLIC_BASE_URL=http://localhost:4000

# Uploaded visa documents (passport scans, photos). Stored on disk in dev;
# swap for object storage (S3) before launch.
# UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=5242880
MAX_DOCUMENTS_PER_REQUEST=8

# Payment gateway. "simulated" is a built-in test gateway that needs no
# credentials and completes payments from the browser (dev/staging only).
# Use "ngenius" for the real Network International integration.
PAYMENT_PROVIDER=simulated

# Real N-Genius (Network International) credentials — only needed when
# PAYMENT_PROVIDER=ngenius.
# NGENIUS_API_KEY=
# NGENIUS_OUTLET_REF=
# NGENIUS_GATEWAY_URL=https://api-gateway.ngenius-payments.com
